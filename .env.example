# ========================================
# 自動化發文平台 - 環境變數設定
# 複製此檔案為 .env 並填入實際值
# ========================================

# 資料庫連線（MySQL）
# 格式：mysql://使用者:密碼@主機:埠/資料庫名稱
DATABASE_URL=mysql://autopost:your_password@127.0.0.1:3306/autopost

# JWT Session 金鑰（請改為隨機長字串，至少 32 字元）
JWT_SECRET=please-change-this-to-a-random-secret-string-at-least-32-chars

# 應用程式埠號
PORT=3000

# 應用程式 ID（可保持預設）
APP_ID=auto-post-platform

# Node 環境
NODE_ENV=production
